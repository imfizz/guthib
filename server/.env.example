# MongoDB Atlas connection string. Get this from Atlas:
#   Cluster > Connect > Drivers > copy the connection string.
# Replace <username>, <password>, and the cluster host with your own.
# Remember to URL-encode any special characters in the password.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of the database to use inside the cluster.
MONGO_DB=bhandol
